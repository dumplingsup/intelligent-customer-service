# OpenAI API Configuration
OPENAI_API_KEY=your_api_key_here

# Application Settings
APP_HOST=0.0.0.0
APP_PORT=8000

# Chroma DB Settings
CHROMA_PERSIST_DIR=./chroma_db

# Model Settings
LLM_MODEL=gpt-4
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# RAG Settings
CHUNK_SIZE=500
CHUNK_OVERLAP=50
SIMILARITY_THRESHOLD=0.7
RETRIEVAL_K=3
